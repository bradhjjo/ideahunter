# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ──────────────────────────────────────────────────
# LLM Provider: 'gemini' (default) or 'local'
# ──────────────────────────────────────────────────
LLM_PROVIDER=gemini

# Output language for the AI-generated ideas (default: 한국어)
# Examples: English / 日本語 / Español / Français
RESPONSE_LANGUAGE=한국어

# ── Option A: Gemini (cloud) ──
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Option B: Local LLM (Ollama / LM Studio) ──
# LLM_PROVIDER=local
# LOCAL_LLM_API_BASE=http://localhost:1234/v1   # LM Studio default
# LOCAL_LLM_API_BASE=http://localhost:11434/v1  # Ollama default
# LOCAL_LLM_API_KEY=local-key                   # any non-empty value
# LOCAL_LLM_MODEL=local-model                   # or e.g. llama3

# Timezone / Schedule
TIMEZONE=America/Chicago
SCHEDULE_TIME=07:00
